# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=workout_archive

# Server Settings
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Auth Settings
JWT_SECRET=
COOKIE_SECRET=
MAX_COOKIE_AGE=86400000
BCRYPT_SALT_ROUNDS=10

# Storage Settings
UPLOAD_DIR=./uploads
CACHE_DIR=./cache
PROFILE_UPLOAD_PATH=uploads/profiles
POST_UPLOAD_PATH=uploads/posts
DEFAULT_PROFILE_IMAGE=default_profile.png

# Scheduler Settings
ENABLE_CLEANUP_SCHEDULER=true
ENABLE_USER_CLEANUP=true
